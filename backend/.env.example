# ============================================================
# Evaluate AI Capstone — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ---- Application ----
APP_NAME=Evaluate AI
APP_VERSION=1.0.0
DEBUG=true

# ---- Database (PostgreSQL 17 with pgvector) ----
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/evaluate_ai
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/evaluate_ai

# ---- JWT Authentication ----
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Ollama LLM ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Sentence-BERT ----
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---- QWEN V3 OCR ----
QWEN_MODEL=Qwen/Qwen2-VL-7B-Instruct

# ---- File Storage ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ---- RAG Configuration ----
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500
